{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Calls",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 40 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(visoora_active_calls_gauge)",
          "legendFormat": "Active Calls"
        }
      ]
    },
    {
      "title": "Active Calls by Tenant",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "visoora_active_calls_gauge",
          "legendFormat": "{{tenant_id}}"
        }
      ]
    },
    {
      "title": "P95 LLM Latency (ms)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "red", "value": 1200 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(visoora_llm_latency_histogram_bucket[5m])) by (le))",
          "legendFormat": "P95 Latency"
        }
      ]
    },
    {
      "title": "LLM Latency Distribution",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(visoora_llm_latency_histogram_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(visoora_llm_latency_histogram_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(visoora_llm_latency_histogram_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "title": "Compliance Blocks",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(visoora_compliance_blocks_counter[1h]))",
          "legendFormat": "Blocks (1h)"
        }
      ]
    },
    {
      "title": "VAD Interruptions / min",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(visoora_vad_interruptions_counter[1m])) * 60",
          "legendFormat": "Interruptions/min"
        }
      ]
    },
    {
      "title": "FSM State Transition Heatmap",
      "type": "heatmap",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (from_state, to_state) (increase(visoora_fsm_transitions_counter[5m]))",
          "legendFormat": "{{from_state}} → {{to_state}}"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "short" },
        "color": { "scheme": "Turbo" }
      }
    },
    {
      "title": "Compliance Events Timeline",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60 }
        }
      },
      "targets": [
        {
          "expr": "sum by (reason) (increase(visoora_compliance_blocks_counter[5m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "title": "Call Duration Distribution",
      "type": "histogram",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(visoora_call_duration_histogram_bucket[10m])) by (le)",
          "legendFormat": "{{le}}s",
          "format": "heatmap"
        }
      ]
    },
    {
      "title": "Audio Decode Errors Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "expr": "rate(visoora_audio_decode_errors_counter[5m])",
          "legendFormat": "Decode Errors/sec"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["visoora", "telephony", "observability"],
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(visoora_active_calls_gauge, tenant_id)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Visoora — AI Sales Call Operations",
  "uid": "visoora-ops-dashboard",
  "version": 1
}
