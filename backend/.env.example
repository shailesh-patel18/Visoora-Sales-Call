# =====================================================================
# TWILIO CONFIGURATION (Found in your Twilio Console Dashboard)
# =====================================================================
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_TRIAL_NUMBER=+1234567890

# =====================================================================
# SUPABASE STORAGE & POSTGRES DATABASE CONFIGURATION
# Found in Project Settings > API (https://supabase.com/dashboard)
# =====================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =====================================================================
# APPLICATION SETTINGS
# =====================================================================
APP_ENV=development
LOCAL_WEBRTC_MODE=False
PORT=8000
WEB_CONCURRENCY=1
SERVER_PUBLIC_DOMAIN=your-ngrok-domain.ngrok-free.dev
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SYSTEM_API_KEYS=dev_system_key_change_me
MAX_ACTIVE_CALLS_PER_NODE=50
MAX_TRANSCRIPT_TURNS_PER_CALL=300

# =====================================================================
# REDIS
# Required in production for distributed rate limiting and call routing.
# Leave blank in local development to use in-memory fallbacks.
# =====================================================================
REDIS_URL=

# =====================================================================
# AI API KEYS
# =====================================================================
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIzaSy...
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
