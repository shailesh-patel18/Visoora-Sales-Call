{
    "workflow_name": "Autopilot_Discovery_and_Prospecting",
    "version": 1,
    "steps": [
        {
            "step_id": "step_1_research_company",
            "action": "execute_agent",
            "agent_type": "ResearchAgent",
            "depends_on": [],
